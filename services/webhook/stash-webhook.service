[Unit]
Description=Stash TikTok webhook receiver
After=network.target

[Service]
Type=simple
User=stash
Group=stash
WorkingDirectory=/opt/stash-webhook
EnvironmentFile=-/etc/stash-webhook/env
ExecStart=/opt/stash-webhook/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3
StateDirectory=stash-webhook

[Install]
WantedBy=multi-user.target
